# CodePilot local environment example.
# Replace placeholders before using production values.

CODEPILOT_ENVIRONMENT=development
CODEPILOT_APP_NAME=CodePilot
CODEPILOT_APP_VERSION=0.1.0
CODEPILOT_API_HOST=0.0.0.0
CODEPILOT_API_PORT=8000
CODEPILOT_SECRET_KEY=change-me-in-production
CODEPILOT_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CODEPILOT_TRUSTED_HOSTS=localhost,127.0.0.1,api,frontend
CODEPILOT_MAX_REQUEST_SIZE_BYTES=1048576

# Local service endpoints used by the API and worker.
CODEPILOT_DATABASE_URL=postgresql+asyncpg://codepilot:codepilot@postgres:5432/codepilot
CODEPILOT_DATABASE_POOL_SIZE=5
CODEPILOT_DATABASE_MAX_OVERFLOW=10
CODEPILOT_DATABASE_POOL_TIMEOUT_SECONDS=30
CODEPILOT_DATABASE_CONNECT_TIMEOUT_SECONDS=5
CODEPILOT_DATABASE_STATEMENT_TIMEOUT_MS=10000
CODEPILOT_DATABASE_HEALTH_TIMEOUT_SECONDS=2.0
CODEPILOT_REDIS_URL=redis://redis:6379/0
CODEPILOT_REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=2.0
CODEPILOT_REDIS_SOCKET_TIMEOUT_SECONDS=2.0
CODEPILOT_REDIS_HEALTH_TIMEOUT_SECONDS=2.0
CODEPILOT_REDIS_HEALTH_CHECK_INTERVAL_SECONDS=30
CODEPILOT_QDRANT_URL=http://qdrant:6333
CODEPILOT_QDRANT_HEALTH_TIMEOUT_SECONDS=2.0
CODEPILOT_OLLAMA_BASE_URL=http://ollama:11434
CODEPILOT_OLLAMA_HEALTH_TIMEOUT_SECONDS=2.0

# Local model names can be changed per machine.
CODEPILOT_OLLAMA_CHAT_MODEL=qwen2.5-coder:3b
CODEPILOT_OLLAMA_EMBEDDING_MODEL=nomic-embed-text
CODEPILOT_OLLAMA_MODEL_REQUIRED=false

# Worker and idempotency defaults.
CODEPILOT_CELERY_TASK_TIME_LIMIT_SECONDS=600
CODEPILOT_CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=540
CODEPILOT_CELERY_RESULT_EXPIRES_SECONDS=3600
CODEPILOT_CELERY_WORKER_PREFETCH_MULTIPLIER=1
CODEPILOT_IDEMPOTENCY_TTL_SECONDS=86400

# Authentication. Production requires a random secret of at least 32 characters.
CODEPILOT_ACCESS_TOKEN_TTL_SECONDS=900
CODEPILOT_REFRESH_TOKEN_TTL_SECONDS=2592000
CODEPILOT_ACCESS_TOKEN_ALGORITHM=HS256
CODEPILOT_REFRESH_COOKIE_NAME=codepilot_refresh
CODEPILOT_CSRF_COOKIE_NAME=codepilot_csrf
CODEPILOT_COOKIE_SECURE=false
CODEPILOT_AUTH_RATE_LIMIT_WINDOW_SECONDS=60
CODEPILOT_REGISTRATION_RATE_LIMIT=5
CODEPILOT_LOGIN_RATE_LIMIT=10
CODEPILOT_REFRESH_RATE_LIMIT=30
CODEPILOT_PASSWORD_VERIFY_RATE_LIMIT=20
CODEPILOT_AUTHENTICATED_API_RATE_LIMIT=300
CODEPILOT_AUTH_RATE_LIMIT_FAIL_CLOSED=true

# Frontend
VITE_API_BASE_URL=/api/v1
